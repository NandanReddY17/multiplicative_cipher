if __name__ == "__main__":
    original_text = "HACK THE PLANET"
    cipher_key = 7  # 7 is coprime to 26
    
    print(f"Original Text: {original_text}")
    print(f"Key Used:      {cipher_key}\n")
    
    # Encrypt
    encrypted_message = multiplicative_encrypt(original_text, cipher_key)
    print(f"Encrypted:     {encrypted_message}")
    
    # Decrypt
    decrypted_message = multiplicative_decrypt(encrypted_message, cipher_key)
    print(f"Decrypted:     {decrypted_message}")
