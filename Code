        }
    } catch (...) {
        cout << "Invalid key input! Must be a valid integer.\n";
    }
}

// ==========================================
// 2. MATRIX MULTIPLICATION
// ==========================================
void runMatrixMultiplication() {
    cout << "\n--- Matrix Multiplication (2x2) ---\n";
    int a[2][2] = {{1, 2}, {3, 4}};
    int b[2][2] = {{2, 0}, {1, 2}};
    int c[2][2] = {{0, 0}, {0, 0}};

    cout << "Multiplying Matrix A and Matrix B...\nResult:\n";
    for (int i = 0; i < 2; i++) {
        for (int j = 0; j < 2; j++) {
            for (int k = 0; k < 2; k++) {
                c[i][j] += a[i][k] * b[k][j];
            }
            cout << c[i][j] << " ";
        }
        cout << "\n";
    }
}

// ==========================================
// 3. RECURSIVE FACTORIAL
// ==========================================
long long factorial(int n) {
    if (n <= 1) return 1;
    return n * factorial(n - 1);
}

void runFactorial() {
    cout << "\n--- Recursive Factorial ---\n";
    cout << "Enter a number to find its factorial: ";
    string inputStr;
    getline(cin, inputStr);

    try {
        int n = stoi(inputStr);
        if (n < 0) {
            cout << "Error: Factorial is not defined for negative numbers.\n";
        } else if (n > 20) {
            cout << "Careful! Results for n > 20 will overflow standard data types.\n";
        } else {
            cout << n << "! = " << factorial(n) << "\n";
        }
    } catch (...) {
        cout << "Invalid input. Please enter a valid integer.\n";
    }
}
